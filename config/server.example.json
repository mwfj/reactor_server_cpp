{
    "bind_host": "127.0.0.1",
    "bind_port": 8080,
    "max_connections": 10000,
    "idle_timeout_sec": 300,
    "worker_threads": 3,
    "max_header_size": 8192,
    "max_body_size": 1048576,
    "max_ws_message_size": 16777216,
    "request_timeout_sec": 30,
    "tls": {
        "enabled": false,
        "cert_file": "",
        "key_file": "",
        "min_version": "1.2"
    },
    "log": {
        "level": "info",
        "file": "",
        "max_file_size": 10485760,
        "max_files": 3
    },
    "rate_limit": {
        "enabled": false,
        "dry_run": false,
        "status_code": 429,
        "include_headers": true,
        "zones": [
            {
                "name": "per_ip",
                "rate": 100,
                "capacity": 200,
                "key_type": "client_ip",
                "max_entries": 100000,
                "applies_to": []
            }
        ]
    }
}
